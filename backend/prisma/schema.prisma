generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  ADMIN
  OWNER
}

model User {
  id           Int      @id @default(autoincrement())
  telegramId   String   @unique
  username     String?
  firstName    String
  lastName     String?
  photoUrl     String?
  languageCode String?
  isPremium    Boolean  @default(false)
  role         UserRole @default(USER)
  lastLoginAt  DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Product {
  id           Int      @id @default(autoincrement())
  title        String
  description  String
  price        Decimal
  category     String
  wood         String?
  size         String?
  managerLink  String
  coverImage   String
  createdAt    DateTime @default(now())
}

model Gallery {
  id        Int      @id @default(autoincrement())
  title     String?
  image     String
  createdAt DateTime @default(now())
}

model Settings {
  id        Int     @id @default(1)
  phone     String?
  telegram  String?
  whatsapp  String?
  email     String?
  instagram String?
}
